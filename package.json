{
  "name": "@bgantavya/dts-tracer",
  "version": "1.0.0",
  "description": "Distributed tracing middleware for Express",
  "keywords": [
    "tracing",
    "logging",
    "middleware",
    "express"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgantavya/distributed-tracing-system.git"
  },
  "license": "MIT",
  "author": "Gantavya Bansal",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "tsx --test"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
